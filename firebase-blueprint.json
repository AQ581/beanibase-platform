{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information, preference, and subscription status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "cushionFluffiness": { "type": "integer" },
        "trialMessagesUsed": { "type": "integer" },
        "subscriptionType": { "type": "string", "enum": ["free", "monthly", "lifetime"] },
        "subscriptionExpiry": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "CheckIn": {
      "title": "Check-In",
      "description": "Records of user check-ins with coaches.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "coachId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "reflection": { "type": "string" }
      },
      "required": ["uid", "coachId", "timestamp"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "Stores chat history with specific coaches.",
      "type": "object",
      "properties": {
        "coachId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "summary": { "type": "string" }
      },
      "required": ["coachId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Root user profile document."
    },
    "/users/{userId}/checkIns/{checkInId}": {
      "schema": "CheckIn",
      "description": "Historical check-in logs for the user."
    },
    "/users/{userId}/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Chat sessions per coach."
    }
  }
}
