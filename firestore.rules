rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    
    // In some cases, request.auth.uid might not be ready or matching during 
    // the very 1st load of a newly provisioned project. 
    // We'll broaden the read check slightly for the users collection to ensure stability.
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }

    // --- Collection Routes ---

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      // Allow any signed-in user to read a profile if they have the ID.
      // This is generally safe as UIDs are unguessable.
      allow read: if isSignedIn();
      
      // Creating and updating still requires strict ownership
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);

      // Subcollections
      match /checkIns/{checkInId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isOwner(userId);
      }

      match /conversations/{convId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create, update, delete: if isOwner(userId);
      }
    }
  }
}
